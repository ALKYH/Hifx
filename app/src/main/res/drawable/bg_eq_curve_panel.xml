<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <corners android:radius="16dp" />

    <gradient
        android:angle="315"
        android:endColor="#1A9BC6FF"
        android:startColor="#12000000"
        android:type="linear" />

    <stroke
        android:width="1dp"
        android:color="#4D9DB3D8" />

    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp" />
</shape>
