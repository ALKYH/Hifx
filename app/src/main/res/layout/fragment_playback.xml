<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:cardCornerRadius="22dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/library_title"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

            <TextView
                android:id="@+id/text_scan_folder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/library_scan_folder_default"
                android:textAppearance="?attr/textAppearanceBodySmall" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_request_permission"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/action_grant_audio_permission"
                android:visibility="gone"
                app:icon="@android:drawable/ic_dialog_alert" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_library"
        style="@style/Widget.Material3.TabLayout.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabIndicatorAnimationMode="elastic"
        app:tabIndicatorFullWidth="false"
        app:tabInlineLabel="true">

        <com.google.android.material.tabs.TabItem
            android:text="@string/library_tab_all" />

        <com.google.android.material.tabs.TabItem
            android:text="@string/library_tab_album" />

        <com.google.android.material.tabs.TabItem
            android:text="@string/library_tab_artist" />
    </com.google.android.material.tabs.TabLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="6dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_library"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingEnd="26dp"
            android:paddingBottom="12dp" />

        <com.example.hifx.ui.AlphabetIndexView
            android:id="@+id/view_alpha_index"
            android:layout_width="26dp"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="2dp"
            android:contentDescription="@string/library_alpha_index_desc"
            android:paddingTop="10dp"
            android:paddingBottom="14dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_index_hint"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_index_hint_bubble"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/text_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/library_empty"
                android:textAppearance="?attr/textAppearanceBodyMedium" />
        </LinearLayout>

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_library"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
