<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_request_permission"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="@string/action_grant_audio_permission"
        android:visibility="gone"
        app:icon="@android:drawable/ic_dialog_alert" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="6dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_library"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingEnd="26dp"
            android:paddingBottom="12dp" />

        <com.example.hifx.ui.AlphabetIndexView
            android:id="@+id/view_alpha_index"
            android:layout_width="26dp"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="2dp"
            android:contentDescription="@string/library_alpha_index_desc"
            android:paddingTop="10dp"
            android:paddingBottom="14dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_index_hint"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_index_hint_bubble"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/text_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/library_empty"
                android:textAppearance="?attr/textAppearanceBodyMedium" />
        </LinearLayout>

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_library"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layout_floating_top_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:gravity="end"
            android:orientation="vertical"
            android:paddingBottom="12dp"
            android:clipToPadding="false">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layout_search_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="10dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/library_search_hint"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="18dp"
                        app:boxCornerRadiusTopEnd="18dp"
                        app:boxCornerRadiusBottomStart="18dp"
                        app:boxCornerRadiusBottomEnd="18dp"
                        app:endIconMode="clear_text"
                        app:startIconDrawable="@android:drawable/ic_menu_search">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_library_search"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layout_tabs_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorSurfaceContainer"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_library"
                    style="@style/Widget.Material3.TabLayout.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp"
                    app:tabIndicatorAnimationMode="elastic"
                    app:tabIndicatorFullWidth="false"
                    app:tabInlineLabel="true">

                    <com.google.android.material.tabs.TabItem
                        android:text="@string/library_tab_all" />

                    <com.google.android.material.tabs.TabItem
                        android:text="@string/library_tab_album" />

                    <com.google.android.material.tabs.TabItem
                        android:text="@string/library_tab_artist" />
                </com.google.android.material.tabs.TabLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layout_top_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_toggle_search"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/library_toggle_search_expand"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="40dp"
                    android:text=""
                    app:icon="@android:drawable/ic_menu_search"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_sort_mode"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:contentDescription="@string/library_sort_button"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="40dp"
                    android:text=""
                    app:icon="@android:drawable/ic_menu_sort_by_size"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_toggle_tabs"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:contentDescription="@string/library_toggle_tabs_expand"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="40dp"
                    android:text=""
                    app:icon="@android:drawable/ic_menu_today"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
