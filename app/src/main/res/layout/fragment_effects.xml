<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="24dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_effects_enabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/effects_master_switch" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/effects_master_hint"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

                <TextView
                    android:id="@+id/text_reverb_meter_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/effects_reverb_meter_default"
                    android:textAppearance="?attr/textAppearanceLabelMedium" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_reverb_meter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:minHeight="6dp"
                    app:trackCornerRadius="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_effects"
            style="@style/Widget.Material3.TabLayout.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabIndicatorAnimationMode="elastic"
            app:tabIndicatorFullWidth="false">

            <com.google.android.material.tabs.TabItem
                android:text="@string/effects_tab_eq" />

            <com.google.android.material.tabs.TabItem
                android:text="@string/effects_tab_reverb" />

            <com.google.android.material.tabs.TabItem
                android:text="@string/effects_tab_other" />
        </com.google.android.material.tabs.TabLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="24dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <FrameLayout
                android:id="@+id/effects_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/panel_eq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/effects_equalizer"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/effects_eq_hint"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fillViewport="true"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <include
                                android:id="@+id/band_1"
                                layout="@layout/item_eq_band_vertical" />

                            <include
                                android:id="@+id/band_2"
                                layout="@layout/item_eq_band_vertical" />

                            <include
                                android:id="@+id/band_3"
                                layout="@layout/item_eq_band_vertical" />

                            <include
                                android:id="@+id/band_4"
                                layout="@layout/item_eq_band_vertical" />

                            <include
                                android:id="@+id/band_5"
                                layout="@layout/item_eq_band_vertical" />

                            <include
                                android:id="@+id/band_6"
                                layout="@layout/item_eq_band_vertical" />

                            <include
                                android:id="@+id/band_7"
                                layout="@layout/item_eq_band_vertical" />

                            <include
                                android:id="@+id/band_8"
                                layout="@layout/item_eq_band_vertical" />
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panel_reverb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/effects_reverb_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_spatial_enabled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/effects_spatial_enabled" />

                    <TextView
                        android:id="@+id/text_spatial_distance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/effects_spatial_distance_default"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <TextView
                        android:id="@+id/text_spatial_gain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/effects_spatial_gain_default"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_channel_position"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant"
                        app:cardCornerRadius="16dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/effects_channel_position_option"
                                android:textAppearance="?attr/textAppearanceLabelLarge" />

                            <TextView
                                android:id="@+id/text_channel_mode_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/effects_channel_mode_linked"
                                android:textAppearance="?attr/textAppearanceBodySmall" />

                            <TextView
                                android:id="@+id/text_channel_position_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/effects_channel_position_summary_default"
                                android:textAppearance="?attr/textAppearanceBodySmall" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:id="@+id/layout_channel_position_panel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:padding="4dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/effects_pos_hint_dual"
                            android:textAppearance="?attr/textAppearanceBodySmall" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_channel_separated"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/effects_channel_separate_switch" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/button_select_left"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/effects_channel_left_label" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/button_select_right"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="@string/effects_channel_right_label" />
                        </LinearLayout>

                        <com.example.hifx.ui.SpatialPadView
                            android:id="@+id/spatial_pad_dual"
                            android:layout_width="match_parent"
                            android:layout_height="260dp"
                            android:layout_marginTop="10dp"
                            android:background="?attr/colorSecondaryContainer" />

                        <TextView
                            android:id="@+id/text_pos_xz_dual"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="?attr/textAppearanceBodySmall" />

                        <TextView
                            android:id="@+id/text_radius_selected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="?attr/textAppearanceLabelSmall" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_radius_selected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stepSize="1"
                            android:value="100"
                            android:valueFrom="20"
                            android:valueTo="100" />

                        <TextView
                            android:id="@+id/text_pos_x_selected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="?attr/textAppearanceLabelSmall" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_pos_x_selected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stepSize="1"
                            android:value="0"
                            android:valueFrom="-100"
                            android:valueTo="100" />

                        <TextView
                            android:id="@+id/text_pos_y_selected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="?attr/textAppearanceLabelSmall" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_pos_y_selected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stepSize="1"
                            android:value="0"
                            android:valueFrom="-100"
                            android:valueTo="100" />

                        <TextView
                            android:id="@+id/text_pos_z_selected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="?attr/textAppearanceLabelSmall" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_pos_z_selected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stepSize="1"
                            android:value="0"
                            android:valueFrom="-100"
                            android:valueTo="100" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant"
                        app:cardCornerRadius="16dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/effects_surround_mode_title"
                                android:textAppearance="?attr/textAppearanceLabelLarge" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/effects_surround_mode_hint"
                                android:textAppearance="?attr/textAppearanceBodySmall" />

                            <com.google.android.material.button.MaterialButtonToggleGroup
                                android:id="@+id/toggle_surround_mode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                app:singleSelection="true">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/button_surround_stereo"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/effects_surround_mode_stereo" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/button_surround_5_1"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/effects_surround_mode_5_1" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/button_surround_7_1"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/effects_surround_mode_7_1" />
                            </com.google.android.material.button.MaterialButtonToggleGroup>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant"
                        app:cardCornerRadius="16dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/effects_convolution_title"
                                android:textAppearance="?attr/textAppearanceLabelLarge" />

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/switch_convolution_enabled"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="@string/effects_convolution_enabled" />

                            <TextView
                                android:id="@+id/text_convolution_ir_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/effects_convolution_ir_not_loaded"
                                android:textAppearance="?attr/textAppearanceBodySmall" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/button_import_irs"
                                    style="@style/Widget.Material3.Button.TonalButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/effects_convolution_import" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/button_clear_irs"
                                    style="@style/Widget.Material3.Button.TextButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="@string/effects_convolution_clear" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/text_convolution_wet_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textAppearance="?attr/textAppearanceBodySmall" />

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slider_convolution_wet"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:stepSize="1"
                                android:value="35"
                                android:valueFrom="0"
                                android:valueTo="100" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panel_other"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/effects_sound_color"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/effects_bass"
                        android:textAppearance="?attr/textAppearanceLabelLarge" />

                    <TextView
                        android:id="@+id/text_bass_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/effect_percent_default"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_bass"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="1"
                        android:value="400"
                        android:valueFrom="0"
                        android:valueTo="1000" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/effects_virtualizer"
                        android:textAppearance="?attr/textAppearanceLabelLarge" />

                    <TextView
                        android:id="@+id/text_virtualizer_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/effect_percent_default"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_virtualizer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="1"
                        android:value="300"
                        android:valueFrom="0"
                        android:valueTo="1000" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/effects_loudness"
                        android:textAppearance="?attr/textAppearanceLabelLarge" />

                    <TextView
                        android:id="@+id/text_loudness_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/effect_gain_default"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/slider_loudness"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="1"
                        android:value="0"
                        android:valueFrom="0"
                        android:valueTo="2000" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
