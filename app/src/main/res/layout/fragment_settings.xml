<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/layout_submenu_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_submenu_back"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_submenu_back"
                app:icon="@android:drawable/ic_media_previous" />

            <TextView
                android:id="@+id/text_submenu_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceTitleMedium" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_root_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_menu_appearance"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_menu_appearance"
                app:icon="@android:drawable/ic_menu_gallery" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_menu_playback"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_menu_playback"
                app:icon="@android:drawable/ic_lock_silent_mode_off" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_menu_lyrics"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_menu_lyrics"
                app:icon="@android:drawable/ic_menu_edit" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_menu_library"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_menu_library"
                app:icon="@android:drawable/ic_menu_agenda" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_menu_other"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_menu_other"
                app:icon="@android:drawable/ic_menu_manage" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_menu_about"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_menu_about"
                app:icon="@android:drawable/ic_menu_info_details" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/section_appearance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="24dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_appearance_title"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <RadioGroup
                    android:id="@+id/group_theme_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radio_theme_system"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_mode_system" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radio_theme_light"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_mode_light" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radio_theme_dark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_mode_dark" />
                </RadioGroup>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_background_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_background_card_title"
                            android:textAppearance="?attr/textAppearanceTitleSmall" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_background_dynamic"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/settings_background_dynamic_switch" />

                        <TextView
                            android:id="@+id/text_background_blur_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/settings_background_blur_value"
                            android:textAppearance="?attr/textAppearanceLabelLarge" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_background_blur"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:stepSize="1"
                            android:valueFrom="0"
                            android:valueTo="100" />

                        <TextView
                            android:id="@+id/text_background_opacity_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/settings_background_opacity_value"
                            android:textAppearance="?attr/textAppearanceLabelLarge" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_background_opacity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:stepSize="1"
                            android:valueFrom="0"
                            android:valueTo="100" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/section_playback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="24dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_playback_title"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_hi_fi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_hifi_switch" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_hi_res_api"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_hires_api_switch" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_remember_playback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_remember_playback_switch" />

                <TextView
                    android:id="@+id/text_hi_fi_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_hifi_on_hint"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

                <TextView
                    android:id="@+id/text_sample_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_sample_rate_default"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_output_sample_rate_title"
                    android:textAppearance="?attr/textAppearanceLabelLarge" />

                <Spinner
                    android:id="@+id/spinner_output_sample_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/text_frames_per_buffer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/settings_buffer_default"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <TextView
                    android:id="@+id/text_offload_support"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/settings_offload_default"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_bit_depth_title"
                    android:textAppearance="?attr/textAppearanceLabelLarge" />

                <Spinner
                    android:id="@+id/spinner_bit_depth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_bitrate_title"
                    android:textAppearance="?attr/textAppearanceLabelLarge" />

                <Spinner
                    android:id="@+id/spinner_max_bitrate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_usb_route_title"
                    android:textAppearance="?attr/textAppearanceLabelLarge" />

                <Spinner
                    android:id="@+id/spinner_usb_dac"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_usb_exclusive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_usb_exclusive_switch" />

                <TextView
                    android:id="@+id/text_active_route"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/settings_active_route_default"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

                <TextView
                    android:id="@+id/text_usb_exclusive_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_usb_exclusive_state_default"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_refresh_device_info"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/action_refresh_device_info"
                    app:icon="@android:drawable/ic_popup_sync" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_show_audio_pipeline_details"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_pipeline_details_button"
                    app:icon="@android:drawable/ic_menu_info_details" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/section_lyrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="24dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_lyrics_title"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_show_lyrics_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_show_lyrics_panel_switch" />

                <TextView
                    android:id="@+id/text_lyrics_font_size_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_lyrics_font_size_value"
                    android:textAppearance="?attr/textAppearanceLabelLarge" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_lyrics_font_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:stepSize="1"
                    android:valueFrom="12"
                    android:valueTo="40" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_lyrics_bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_lyrics_bold_switch" />

                <TextView
                    android:id="@+id/text_lyrics_glow_intensity_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_lyrics_glow_intensity_value"
                    android:textAppearance="?attr/textAppearanceLabelLarge" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_lyrics_glow_intensity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:stepSize="1"
                    android:valueFrom="0"
                    android:valueTo="100" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_lyrics_font_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <TextView
                        android:id="@+id/text_lyrics_font_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="@string/settings_lyrics_font_preview_text"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/section_library"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="24dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_library_title"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <TextView
                    android:id="@+id/text_scan_folder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/library_scan_folder_default"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_select_scan_folder"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/action_select_scan_folder"
                    app:icon="@android:drawable/ic_menu_upload" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_clear_scan_folder"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/action_clear_scan_folder" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_rescan_library"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/action_rescan_library"
                    app:icon="@android:drawable/ic_popup_sync" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/section_other"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="24dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_other_title"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_haptic_feedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_haptic_feedback_switch" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/section_about"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="24dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_about_title"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <TextView
                    android:id="@+id/text_about_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/settings_about_desc"
                    android:textAppearance="?attr/textAppearanceBodySmall" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</ScrollView>
